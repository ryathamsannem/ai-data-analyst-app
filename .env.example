# =============================================================================
# AI Data Analyst — environment template
# Copy to backend/.env for local backend secrets (gitignored).
# Vercel / Render: set variables in each platform dashboard (see deployment-guide.md).
# =============================================================================

# --- Backend (FastAPI) — Render Web Service ---

# Required in production (APP_ENV=production)
ANTHROPIC_API_KEY=

# production | development
APP_ENV=development

# Comma-separated browser origins (no trailing slashes)
# Local:    http://localhost:3000
# Vercel:   https://your-app.vercel.app,https://your-app-git-main-you.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Set false only if AI narrative is disabled
AI_NARRATIVE_ENABLED=true

# Render sets PORT automatically — used by startCommand in render.yaml (do not set locally unless needed)
# PORT=8000

# --- Frontend (Next.js) — Vercel Project → Environment Variables ---

# Build-time: backend public URL (no trailing slash)
# Local:  http://localhost:8000
# Render: https://ai-data-analyst-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Optional ---

# Frontend debug panels (AI Insights)
# NEXT_PUBLIC_AI_INSIGHTS_DEBUG=false

# Backend intent engine override
# INTENT_ENGINE_DISABLE=false

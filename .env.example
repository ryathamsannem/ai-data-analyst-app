# Backend (FastAPI)
ANTHROPIC_API_KEY=
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
AI_NARRATIVE_ENABLED=true

# Frontend (Next.js — set at build time)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional debug (frontend)
# NEXT_PUBLIC_AI_INSIGHTS_DEBUG=false

# Optional intent engine override (backend)
# INTENT_ENGINE_DISABLE=false
